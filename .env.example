# MongoDB
MONGODB_URI=mongodb://localhost:27017/oceanic_ai

# Server
PORT=8000

# JWT (required)
JWT_SECRET=your-secret-key

# OpenAI (image generation)
OPENAI_API_KEY=

# Gmail OTP (app password recommended). If unset, the OTP is only printed in the server console.
EMAIL_USER=
EMAIL_PASS=

# Google Sign-In (Web client ID from Google Cloud Console — same as AssistantAppBacken user-service)
GOOGLE_CLIENT_ID=
